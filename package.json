{
  "name": "spoonfeeder",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dashboard": "python3 ../../dashboard/tools/project_dashboard.py .",
    "quality": "mkdir -p reports && eslint src/ts --ext .vue,.js,.ts --format json --output-file reports/eslint.json; ESLINT=$?; node ../../dashboard/tools/tsc_json.mjs . vue-tsc --allowJs --noEmit -p tsconfig.typecheck.json --composite false; TSC=$?; npx vitest --run --reporter=json --outputFile=reports/vitest.json --coverage; TEST=$?; npm audit --json > reports/npm-audit.json 2>/dev/null; node ../../dashboard/tools/write_quality_json.mjs . typescript; echo \"Quality: eslint=$ESLINT tsc=$TSC test=$TEST\"; exit $((ESLINT|TSC|TEST))",
    "upgrade": "npx npm-check-updates --interactive",
    "circular": "dpdm --transform --no-warning --no-tree --exit-code circular:1 src/ts/main/quiz/quiz.ts",
    "type-check": "vue-tsc --allowJs --noEmit -p tsconfig.typecheck.json --composite false",
    "lint": "eslint src/ts --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-pattern .gitignore",
    "format": "prettier --loglevel=warn --write --single-quote \"src/ts/**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test:unit": "vitest --run",
    "test:mutation": "stryker run",
    "test:e2e": "CHOKIDAR_USEPOLLING=true start-server-and-test 'quasar dev --port 9100' http://127.0.0.1:9100 'npx cypress run -q --config baseUrl=http://127.0.0.1:9100'",
    "test:e2e:open": "npx cypress open",
    "test:e2e:snapshot": "CHOKIDAR_USEPOLLING=true start-server-and-test 'quasar dev --port 9100' http://127.0.0.1:9100 'npx cypress run --spec cypress/e2e/snapshot.cy.ts --config baseUrl=http://127.0.0.1:9100,excludeSpecPattern=[]'",
    "build-only": "vite build",
    "test:all": "yarn type-check && yarn lint && yarn test:unit && yarn test:e2e",
    "android:build": "quasar build -m capacitor -T android --debug",
    "android:deploy": "adb install -r dist/capacitor/android/apk/debug/app-debug.apk",
    "knip": "knip",
    "scan:deps": "npx dependency-cruiser --config analysis/dependency-cruiser.config.cjs src/ts",
    "scan:storage": "node scripts/storage-key-audit.ts",
    "scan:security": "node scripts/security-scan.ts",
    "scan:sideeffects": "node scripts/side-effect-scanner.ts",
    "scan:clusters": "node scripts/boolean-cluster-scanner.ts",
    "scan:perf": "node scripts/perf-scan.ts",
    "scan:infra": "node scripts/infra-audit.ts",
    "test:property": "vitest --run --reporter=verbose property",
    "ai:validate": "node scripts/ai-patch-validate.ts",
    "test:baseline": "node scripts/differential-replay.ts --record",
    "test:diff": "node scripts/differential-replay.ts --diff",
    "verify": "yarn type-check && yarn lint && yarn test:unit && yarn test:property && yarn scan:storage && yarn scan:sideeffects && yarn scan:security && yarn scan:deps && yarn test:e2e"
  },
  "dependencies": {
    "@quasar/extras": "1.18.0",
    "@tanem/svg-injector": "11.3.2",
    "axios": "1.16.0",
    "downdoc": "1.1.0-stable",
    "dpdm": "4.0.1",
    "gsap": "3.15.0",
    "handlebars": "4.7.9",
    "highlight.js": "11.11.1",
    "jquery": "4.0.0",
    "js-yaml": "4.1.1",
    "lodash": "4.18.1",
    "marked": "18.0.3",
    "mathjax-full": "3.2.2",
    "mobile-drag-drop": "3.0.0-rc.0",
    "normalize.css": "8.0.1",
    "pinia": "3.0.4",
    "polyfill-library": "4.8.0",
    "quasar": "2.19.3",
    "typescript-eslint": "8.59.2",
    "vue": "3.5.34",
    "vue-i18n": "11.4.2",
    "vue-router": "5.0.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@intlify/vite-plugin-vue-i18n": "7.0.0",
    "@quasar/app-vite": "2.6.0",
    "@rushstack/eslint-patch": "1.16.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/jquery": "4.0.0",
    "@types/js-yaml": "4.0.9",
    "@types/jsdom": "28.0.1",
    "@types/lodash": "4.17.24",
    "@types/marked": "6.0.0",
    "@types/node": "25.6.0",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "@vitest/coverage-v8": "4.1.5",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.7.0",
    "@vue/test-utils": "2.4.10",
    "@vue/tsconfig": "0.9.1",
    "autoprefixer": "10.5.0",
    "cypress": "15.14.2",
    "dependency-cruiser": "^17.4.0",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-cypress": "6.4.1",
    "eslint-plugin-vue": "10.9.1",
    "jsdom": "29.1.1",
    "knip": "^6.12.0",
    "microdiff": "^1.5.0",
    "npm-check-updates": "22.1.1",
    "npm-run-all": "4.1.5",
    "postcss": "8.5.14",
    "prettier": "3.8.3",
    "prettier-plugin-organize-imports": "4.3.0",
    "quasar-app-extension-qhierarchy": "1.0.15",
    "start-server-and-test": "3.0.2",
    "typescript": "6.0.3",
    "vitest": "4.1.5",
    "vitest-mock-extended": "4.0.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "3.2.8"
  },
  "engines": {
    "node": "24",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  },
  "packageManager": "yarn@4.14.1",
  "quality": {
    "coverage": {
      "threshold": 60,
      "_comment": "baseline 60% 2026-05-20; ratchet up as tests are added"
    }
  }
}
