{
  "name": "spoonfeeder",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "upgrade": "npx npm-check-updates --interactive",
    "circular": "dpdm --transform --no-warning --no-tree --exit-code circular:1 src/ts/main/quiz/quiz.ts",
    "type-check": "vue-tsc --allowJs --noEmit -p tsconfig.typecheck.json --composite false",
    "lint": "eslint src/ts --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-pattern .gitignore",
    "format": "prettier --loglevel=warn --write --single-quote \"src/ts/**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test:unit": "vitest --run --environment jsdom --reporter default",
    "test:e2e": "npx cypress run -q",
    "test:e2e:open": "npx cypress open",
    "build-only": "vite build",
    "test:all": "yarn type-check && yarn lint && yarn test:unit && yarn test:e2e",
    "android:build": "quasar build -m capacitor -T android --debug",
    "android:deploy": "adb install -r dist/capacitor/android/apk/debug/app-debug.apk"
  },
  "dependencies": {
    "@iconfu/svg-inject": "2.0.1",
    "@quasar/extras": "1.18.0",
    "@tanem/svg-injector": "11.3.2",
    "@types/mathjax": "0.0.40",
    "asciidoctor": "3.0.4",
    "axios": "1.15.0",
    "downdoc": "^1.1.0-stable",
    "dpdm": "4.0.1",
    "fs": "0.0.1-security",
    "gsap": "3.15.0",
    "handlebars": "4.7.9",
    "highlight.js": "11.11.1",
    "iframe-resizer": "5.5.9",
    "jquery": "4.0.0",
    "js-yaml": "4.1.1",
    "lodash": "4.18.1",
    "marked": "18.0.0",
    "mathjax-full": "3.2.2",
    "mnemonist": "0.40.3",
    "mobile-drag-drop": "3.0.0-rc.0",
    "normalize.css": "8.0.1",
    "pinia": "3.0.4",
    "polyfill-library": "4.8.0",
    "quasar": "2.19.3",
    "typed.js": "3.0.0",
    "typescript-eslint": "8.58.2",
    "vara": "1.4.1",
    "vue": "3.5.32",
    "vue-i18n": "11.3.2",
    "vue-router": "5.0.4",
    "vuedraggable": "4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@intlify/vite-plugin-vue-i18n": "7.0.0",
    "@quasar/app-vite": "2.6.0",
    "@rushstack/eslint-patch": "1.16.1",
    "@types/jquery": "4.0.0",
    "@types/js-yaml": "4.0.9",
    "@types/jsdom": "28.0.1",
    "@types/lodash": "4.17.24",
    "@types/marked": "6.0.0",
    "@types/node": "25.6.0",
    "@typescript-eslint/eslint-plugin": "8.58.2",
    "@typescript-eslint/parser": "8.58.2",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.7.0",
    "@vue/test-utils": "2.4.6",
    "@vue/tsconfig": "0.9.1",
    "autoprefixer": "10.5.0",
    "cypress": "15.14.0",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-cypress": "6.3.1",
    "eslint-plugin-vue": "10.8.0",
    "jsdom": "29.0.2",
    "npm-check-updates": "21.0.2",
    "npm-run-all": "4.1.5",
    "postcss": "8.5.10",
    "prettier": "3.8.3",
    "prettier-plugin-organize-imports": "4.3.0",
    "quasar-app-extension-qhierarchy": "1.0.15",
    "start-server-and-test": "3.0.2",
    "typescript": "6.0.3",
    "vitest": "4.1.4",
    "vitest-mock-extended": "4.0.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "3.2.6"
  },
  "engines": {
    "node": "24",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  },
  "packageManager": "yarn@4.14.1"
}
